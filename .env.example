# Streamflow Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=5177

# ZLMediaKit sidecar addresses used inside docker-compose network.
ZLM_HTTP_ORIGIN=http://zlm:80
ZLM_RTMP_ORIGIN=rtmp://zlm:1935/live
RTSP_PUSH_ORIGIN=rtsp://zlm:554/live

# Capacity and cleanup limits.
MAX_UPSTREAMS=50
MAX_VIEWERS=500
MAX_TRANSCODE_STREAMS=2
TRANSCODE_HEIGHT=540
CLEANUP_AFTER_SECS=120
VIEWER_BUFFER_BYTES=262144

# Resource limits for small servers. 2 vCPU / 2 GiB servers should keep these conservative.
GATEWAY_CPUS=1.6
GATEWAY_MEM_LIMIT=1500m
GATEWAY_PIDS_LIMIT=256
ZLM_CPUS=0.3
ZLM_MEM_LIMIT=256m
ZLM_PIDS_LIMIT=128

# Set to 0 only for tests that should not spawn FFmpeg.
STREAMFLOW_SPAWN_PROCESSES=1

# H265 direct mode pushes the original HEVC stream to ZLMediaKit and lets the browser try a H265 player first.
STREAMFLOW_H265_DIRECT=1
STREAMFLOW_H264_FALLBACK=1

# Optional override for frontend H265 player assets. By default the web demo serves built-in Jessibuca assets.
VITE_JESSIBUCA_SCRIPT_URL=
VITE_JESSIBUCA_DECODER_URL=
